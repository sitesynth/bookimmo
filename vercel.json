{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "de" }],
      "destination": "/de/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "fr" }],
      "destination": "/fr/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "it" }],
      "destination": "/it/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "nl" }],
      "destination": "/nl/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "en" }],
      "destination": "/en/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(DE|AT|CH|LI)" }],
      "destination": "/de/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(FR|BE|LU|MC)" }],
      "destination": "/fr/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(IT|SM|VA)" }],
      "destination": "/it/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(NL)" }],
      "destination": "/nl/index.html"
    },
    {
      "source": "/",
      "destination": "/en/index.html"
    },
    {
      "source": "/de",
      "destination": "/de/index.html"
    },
    {
      "source": "/en",
      "destination": "/en/index.html"
    },
    {
      "source": "/fr",
      "destination": "/fr/index.html"
    },
    {
      "source": "/it",
      "destination": "/it/index.html"
    },
    {
      "source": "/nl",
      "destination": "/nl/index.html"
    }
  ]
}
