{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/page.js": {
      "includeFiles": "{de/index.html,en/index.html,fr/index.html,it/index.html,nl/index.html,index.html}"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/de/",
      "permanent": false
    },
    {
      "source": "/de",
      "destination": "/de/",
      "permanent": false
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/fr",
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/it",
      "destination": "/it/",
      "permanent": false
    },
    {
      "source": "/nl",
      "destination": "/nl/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/de/",
      "destination": "/api/page?lang=de"
    },
    {
      "source": "/en/",
      "destination": "/api/page?lang=en"
    },
    {
      "source": "/fr/",
      "destination": "/api/page?lang=fr"
    },
    {
      "source": "/it/",
      "destination": "/api/page?lang=it"
    },
    {
      "source": "/nl/",
      "destination": "/api/page?lang=nl"
    }
  ]
}
