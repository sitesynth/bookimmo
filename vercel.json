{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/",
      "destination": "/de/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "(DE|AT|CH)"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/fr/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "(FR|BE)"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/it/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "IT"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/nl/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "NL"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/en/index.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:;"
        }
      ]
    }
  ]
}
