{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "destination": "/de/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "(DE|AT|CH)"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/fr/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "(FR|BE)"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/it/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "IT"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/nl/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "NL"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/en/index.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https: blob:; worker-src 'self' blob:; child-src 'self' blob:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/dashboard-home", "destination": "/de/index.html" },
    { "source": "/search", "destination": "/de/index.html" },
    { "source": "/agent", "destination": "/de/index.html" },
    { "source": "/account", "destination": "/de/index.html" },
    { "source": "/Bookmark", "destination": "/de/index.html" },
    { "source": "/log-in", "destination": "/de/index.html" },
    { "source": "/sign-up", "destination": "/de/index.html" },
    { "source": "/forgot-password", "destination": "/de/index.html" },
    { "source": "/privacy-policy", "destination": "/de/index.html" },
    { "source": "/terms-of-service", "destination": "/de/index.html" }
  ]
}
