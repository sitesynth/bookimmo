{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/page.js": {
      "includeFiles": "{de/index.html,en/index.html,fr/index.html,it/index.html,nl/index.html,index.html}"
    },
    "api/directus-bridge.js": {
      "includeFiles": "public/directus-bridge.js"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/api/page?lang=de",
      "permanent": false
    },
    {
      "source": "/de",
      "destination": "/api/page?lang=de",
      "permanent": false
    },
    {
      "source": "/en",
      "destination": "/api/page?lang=en",
      "permanent": false
    },
    {
      "source": "/fr",
      "destination": "/api/page?lang=fr",
      "permanent": false
    },
    {
      "source": "/it",
      "destination": "/api/page?lang=it",
      "permanent": false
    },
    {
      "source": "/nl",
      "destination": "/api/page?lang=nl",
      "permanent": false
    }
  ]
}
