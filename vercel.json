{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "de" }],
      "destination": "/de/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "fr" }],
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "it" }],
      "destination": "/it/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "nl" }],
      "destination": "/nl/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "en" }],
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(DE|AT|CH|LI)" }],
      "destination": "/de/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(FR|BE|LU|MC)" }],
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(IT|SM|VA)" }],
      "destination": "/it/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(NL)" }],
      "destination": "/nl/",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en/",
      "permanent": false
    }
  ]
}
