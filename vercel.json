{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/page.js": {
      "includeFiles": "{de/index.html,en/index.html,fr/index.html,it/index.html,nl/index.html}"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/de/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "(DE|AT|CH)"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/fr/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "(FR|BE)"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/it/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "IT"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/nl/index.html",
      "permanent": false,
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "NL"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/en/index.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https: blob:; worker-src 'self' blob:; child-src 'self' blob:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/de", "destination": "/api/page?lang=de" },
    { "source": "/de/:path*", "destination": "/api/page?lang=de" },
    { "source": "/en", "destination": "/api/page?lang=en" },
    { "source": "/en/:path*", "destination": "/api/page?lang=en" },
    { "source": "/fr", "destination": "/api/page?lang=fr" },
    { "source": "/fr/:path*", "destination": "/api/page?lang=fr" },
    { "source": "/it", "destination": "/api/page?lang=it" },
    { "source": "/it/:path*", "destination": "/api/page?lang=it" },
    { "source": "/nl", "destination": "/api/page?lang=nl" },
    { "source": "/nl/:path*", "destination": "/api/page?lang=nl" },
    { "source": "/dashboard-home", "destination": "/api/page?lang=de" },
    { "source": "/search", "destination": "/api/page?lang=de" },
    { "source": "/agent", "destination": "/api/page?lang=de" },
    { "source": "/account", "destination": "/api/page?lang=de" },
    { "source": "/Bookmark", "destination": "/api/page?lang=de" },
    { "source": "/log-in", "destination": "/api/page?lang=de" },
    { "source": "/sign-up", "destination": "/api/page?lang=de" },
    { "source": "/forgot-password", "destination": "/api/page?lang=de" },
    { "source": "/privacy-policy", "destination": "/api/page?lang=de" },
    { "source": "/terms-of-service", "destination": "/api/page?lang=de" }
  ]
}
