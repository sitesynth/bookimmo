{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "de" }],
      "destination": "/de/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "fr" }],
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "it" }],
      "destination": "/it/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "nl" }],
      "destination": "/nl/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "cookie", "key": "lang", "value": "en" }],
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(DE|AT|CH|LI)" }],
      "destination": "/de/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(FR|BE|LU|MC)" }],
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(IT|SM|VA)" }],
      "destination": "/it/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "(NL)" }],
      "destination": "/nl/",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/de",
      "destination": "/de/",
      "permanent": false
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/fr",
      "destination": "/fr/",
      "permanent": false
    },
    {
      "source": "/it",
      "destination": "/it/",
      "permanent": false
    },
    {
      "source": "/nl",
      "destination": "/nl/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/de", "destination": "/index.html" },
    { "source": "/de/index.html", "destination": "/index.html" },
    { "source": "/de/pages/blog", "destination": "/pages/blog.html" },
    { "source": "/de/pages/blog.html", "destination": "/pages/blog.html" },
    { "source": "/de/_local/:path*", "destination": "/_local/:path*" },
    { "source": "/de/public/:path*", "destination": "/public/:path*" },
    { "source": "/de/assets/:path*", "destination": "/assets/:path*" },

    { "source": "/en", "destination": "/index.html" },
    { "source": "/en/index.html", "destination": "/index.html" },
    { "source": "/en/pages/blog", "destination": "/pages/blog.html" },
    { "source": "/en/pages/blog.html", "destination": "/pages/blog.html" },
    { "source": "/en/_local/:path*", "destination": "/_local/:path*" },
    { "source": "/en/public/:path*", "destination": "/public/:path*" },
    { "source": "/en/assets/:path*", "destination": "/assets/:path*" },

    { "source": "/fr", "destination": "/index.html" },
    { "source": "/fr/index.html", "destination": "/index.html" },
    { "source": "/fr/pages/blog", "destination": "/pages/blog.html" },
    { "source": "/fr/pages/blog.html", "destination": "/pages/blog.html" },
    { "source": "/fr/_local/:path*", "destination": "/_local/:path*" },
    { "source": "/fr/public/:path*", "destination": "/public/:path*" },
    { "source": "/fr/assets/:path*", "destination": "/assets/:path*" },

    { "source": "/it", "destination": "/index.html" },
    { "source": "/it/index.html", "destination": "/index.html" },
    { "source": "/it/pages/blog", "destination": "/pages/blog.html" },
    { "source": "/it/pages/blog.html", "destination": "/pages/blog.html" },
    { "source": "/it/_local/:path*", "destination": "/_local/:path*" },
    { "source": "/it/public/:path*", "destination": "/public/:path*" },
    { "source": "/it/assets/:path*", "destination": "/assets/:path*" },

    { "source": "/nl", "destination": "/index.html" },
    { "source": "/nl/index.html", "destination": "/index.html" },
    { "source": "/nl/pages/blog", "destination": "/pages/blog.html" },
    { "source": "/nl/pages/blog.html", "destination": "/pages/blog.html" },
    { "source": "/nl/_local/:path*", "destination": "/_local/:path*" },
    { "source": "/nl/public/:path*", "destination": "/public/:path*" },
    { "source": "/nl/assets/:path*", "destination": "/assets/:path*" }
  ]
}
